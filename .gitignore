.vscode/
.idea/
*.swp
*.swo
*.sw?
*.sln
*.suo
*.ntvs*
*.njsproj
*~

# Testing - 테스트 커버리지 및 출력
coverage/
.nyc_output/

# Runtime files - 런타임 파일
*.pid
*.pid.lock
*.seed

# Logs - 로그 파일
logs/
*.log
lerna-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Cache - 캐시 파일
.cache/
.eslintcache
.prettierignore
.npm/
.vite/

# Temporary files - 임시 파일
*.tmp
*.bak
*.temp
*.zip
*.tar.gz
*.tgz

